const express = require("express");
const mongoose = require("mongoose");
const cors = require("cors");

const app = express();

app.use(cors());
app.use(express.json());

mongoose.connect("mongodb://127.0.0.1:27017/doubtsphere")
  .then(() => console.log("MongoDB connected ✅"))
  .catch(err => console.log(err));

const doubtSchema = new mongoose.Schema({
  title: String,
  description: String,
  status: { type: String, default: "OPEN" },
  acceptedBy: String
});

const Doubt = mongoose.model("Doubt", doubtSchema);

// TEST
app.get("/", (req, res) => {
  res.send("Server running 🚀");
});

// GET
app.get("/doubts", async (req, res) => {
  const data = await Doubt.find();
  res.json(data);
});

// CREATE
app.post("/doubt", async (req, res) => {
  const data = await Doubt.create(req.body);
  res.json(data);
});

// ACCEPT
app.post("/accept-doubt", async (req, res) => {
  const { doubtId, userId } = req.body;

  const doubt = await Doubt.findById(doubtId);
  if (!doubt) return res.status(404).json({ error: "Not found" });

  if (doubt.status !== "OPEN")
    return res.status(400).json({ error: "Already accepted" });

  doubt.status = "MATCHED";
  doubt.acceptedBy = userId;

  await doubt.save();
  res.json(doubt);
});

app.listen(5000, () => {
  console.log("Server running on port 5000 🚀");
});
